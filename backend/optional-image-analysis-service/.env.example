# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored -- never commit real secrets.

# ESP32-CAM single-frame capture endpoint (LAN HTTP URL).
CAPTURE_URL=http://172.19.15.112/capture

# Firebase Realtime Database URL WITHOUT trailing slash.
# Leave blank to run as a pure local analyzer (no write-back).
FIREBASE_HOST=https://YOUR-PROJECT-default-rtdb.firebaseio.com

# Firebase database secret / auth token used as the ?auth= query param.
FIREBASE_AUTH=YOUR_FIREBASE_DATABASE_SECRET_OR_TOKEN

# Device id (must match the firmware and the app).
DEVICE_ID=fridge_01

# HTTP port for the optional Flask server.
PORT=5000
