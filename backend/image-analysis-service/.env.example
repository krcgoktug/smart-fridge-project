# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored -- never commit real secrets.

# ESP32-CAM base URL (LAN HTTP address, no trailing slash).
# The service fetches frames from <CAMERA_BASE_URL>/capture.
CAMERA_BASE_URL=http://192.168.1.50

# Firebase Realtime Database URL WITHOUT trailing slash.
FIREBASE_HOST=https://YOUR-PROJECT-default-rtdb.firebaseio.com

# Firebase database secret / auth token used as the ?auth= query param.
FIREBASE_AUTH=YOUR_FIREBASE_DATABASE_SECRET_OR_TOKEN

# Device id (must match the firmware and the app).
DEVICE_ID=fridge_01

# Seconds between processing cycles.
LOOP_INTERVAL=5
